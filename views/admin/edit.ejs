<%- include('../partials/head') %>
<%- include('../partials/header') %>
<section class="section narrow" style="margin-inline:auto">
  <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap">
    <h1 style="color:var(--navy);margin:0">تعديل بيانات المتوفّى</h1>
    <a class="btn ghost sm" href="/admin">← رجوع للوحة التحكم</a>
  </div>

  <%
    var statusLabels = { pending: 'قيد المراجعة', approved: 'منشور', rejected: 'مخفي' };
    var statusClass = { pending: 'badge-pending', approved: 'badge-approved', rejected: '' };
  %>
  <p><span class="tag <%= statusClass[d.status] %>">الحالة: <%= statusLabels[d.status] || d.status %></span>
     <a href="/m/<%= d.id %>" target="_blank" class="tag">فتح الصفحة ↗</a></p>

  <form class="card" method="POST" action="/admin/edit/<%= d.id %>" enctype="multipart/form-data">
    <label for="name">اسم المتوفّى <span style="color:var(--danger)">*</span></label>
    <input type="text" id="name" name="name" required maxlength="80" value="<%= d.name %>" />

    <label for="bio">الكلمة / الوصف</label>
    <textarea id="bio" name="bio" maxlength="400"><%= d.bio %></textarea>

    <label>الصورة الحالية</label>
    <% if (d.photo) { %>
      <img src="<%= d.photo %>" alt="" style="width:120px;height:120px;object-fit:cover;border-radius:12px;border:1px solid var(--line)" />
      <label class="check" style="max-width:260px;margin-top:10px">
        <input type="checkbox" name="removePhoto" value="1" /> حذف الصورة الحالية
      </label>
    <% } else { %>
      <div class="muted">لا توجد صورة.</div>
    <% } %>

    <label for="photo">تغيير / إضافة صورة (اختياري)</label>
    <input type="file" id="photo" name="photo" accept="image/*" />
    <div class="hint">لو رفعت صورة جديدة، هتستبدل القديمة.</div>

    <label>الأعمال التي تُهدى إليه</label>
    <div class="checks">
      <% DEEDS.forEach(function(deed){ %>
        <label class="check">
          <input type="checkbox" name="deeds" value="<%= deed.key %>" <%= (d.deeds||[]).indexOf(deed.key) > -1 ? 'checked' : '' %> />
          <%= deed.label %>
        </label>
      <% }); %>
    </div>

    <label for="status">الحالة</label>
    <select id="status" name="status">
      <option value="approved" <%= d.status==='approved'?'selected':'' %>>منشور (ظاهر للناس)</option>
      <option value="pending" <%= d.status==='pending'?'selected':'' %>>قيد المراجعة</option>
      <option value="rejected" <%= d.status==='rejected'?'selected':'' %>>مخفي</option>
    </select>

    <div style="margin-top:22px"><button class="btn block" type="submit">💾 حفظ التعديلات</button></div>
  </form>

  <h2 style="color:var(--navy)">🤲 الأدعية (<%= duas.length %>)</h2>
  <p class="muted">يمكنك حذف أي دعاء كتبه الزوّار.</p>
  <% if (duas.length === 0) { %>
    <div class="card muted center">لا توجد أدعية بعد.</div>
  <% } else { %>
    <% duas.forEach(function(x){ %>
      <div class="dua-item" style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start">
        <div>
          <div class="who"><%= x.name %> <span class="when">· <%= new Date(x.createdAt).toLocaleDateString('ar-EG') %></span></div>
          <div class="txt"><%= x.text %></div>
        </div>
        <form method="POST" action="/admin/dua/delete/<%= x.id %>" onsubmit="return confirm('حذف هذا الدعاء؟')">
          <button class="btn danger sm" type="submit">حذف</button>
        </form>
      </div>
    <% }); %>
  <% } %>

  <div class="card" style="margin-top:24px;background:#fceeee;border-color:#f0caca">
    <b style="color:var(--danger)">حذف نهائي</b>
    <p class="muted" style="margin:6px 0 12px">يحذف صفحة المتوفّى وكل أدعيته وصورته نهائيًا — لا يمكن التراجع.</p>
    <form method="POST" action="/admin/delete/<%= d.id %>" onsubmit="return confirm('تأكيد الحذف النهائي لـ <%= d.name %> وكل أدعيته؟')">
      <button class="btn danger" type="submit">🗑️ حذف نهائي</button>
    </form>
  </div>
</section>
<%- include('../partials/footer') %>
