# Copy this file to .env and edit the values

# Port
PORT=3000

# Environment: development (local) or production (server)
NODE_ENV=development

# Admin dashboard password — change to a strong one before deploying
ADMIN_PASSWORD=admin1234

# Long random string to secure sessions — change before deploying
SESSION_SECRET=change-this-to-a-long-random-string

# Enable (=true) only if your site is served over HTTPS, otherwise login won't work
SECURE_COOKIES=false
